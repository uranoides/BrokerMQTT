             xmlns:local="clr-namespace:MQTT.Publisher"
             StartupUri="Views/PublisherWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MQTT.Sharing;component/Themes/ColorTheme.xaml"/>
                <ResourceDictionary Source="/MQTT.Sharing;component/Themes/DefaultTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>

<UserControl x:Name="myUserControl" x:Class="MQTT.Sharing.Controls.DisplayConnectionSettingsListItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MQTT.Sharing.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border BorderThickness="0 0 0 0.5" BorderBrush="{StaticResource Azure3}">
        <Grid DataContext="{Binding ConnectionSettings, ElementName=myUserControl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left" FontSize="{StaticResource FontSize11}" FontWeight="Medium"
                Text="{Binding ConnectionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="{StaticResource Azure1}"/>
            <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Left" FontSize="{StaticResource FontSize11}" FontWeight="Medium"
                Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="{StaticResource Azure1}"/>
            <TextBlock Grid.Row="0" Grid.Column="2" HorizontalAlignment="Right" FontSize="{StaticResource FontSize11}" FontWeight="Medium"
                Text="{Binding Port, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="{StaticResource Azure1}"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" HorizontalAlignment="Left" FontSize="{StaticResource FontSize11}" FontWeight="Medium"
                Text="{Binding MqttTransCodeProtocolVersion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="{StaticResource Azure1}"/>
            <TextBlock Grid.Row="2" Grid.Column="0" HorizontalAlignment="Left" FontSize="{StaticResource FontSize11}" FontWeight="Medium"
                Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="{StaticResource Azure1}"/>
            <TextBlock Grid.Row="2" Grid.Column="2" HorizontalAlignment="Right" FontSize="{StaticResource FontSize11}" FontWeight="Medium"
                Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="{StaticResource Azure1}"/>
            <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" HorizontalAlignment="Left" FontSize="{StaticResource FontSize11}" FontWeight="Medium"
                Text="{Binding TagVariablesFileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="{StaticResource Azure1}"/>
            <TextBlock Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="3" HorizontalAlignment="Right" FontSize="{StaticResource FontSize11}" FontWeight="Medium"
                Text="{Binding IntervalInSeconds, StringFormat={}{0} sec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="{StaticResource Azure1}"/>
        </Grid>
    </Border>
</UserControl>

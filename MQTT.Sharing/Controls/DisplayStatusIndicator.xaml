<UserControl x:Class="MQTT.Sharing.Controls.DisplayStatusIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MQTT.Sharing.Controls"
             mc:Ignorable="d" d:DesignHeight="20" d:DesignWidth="20">
    <Grid>
        <Ellipse Name="IndicatorEllipse" 
                Width="12" Height="12" 
                Stroke="{StaticResource Azure1}" 
                StrokeThickness="0.5">
            <Ellipse.Style>
                <Style TargetType="Ellipse">
                    <Setter Property="Fill" Value="{StaticResource Red6}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsConnected, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                              Value="True">
                            <Setter Property="Fill" Value="{StaticResource Green6}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Ellipse.Style>
        </Ellipse>
    </Grid>
</UserControl>

<UserControl x:Name="myUserControl" x:Class="MQTT.Sharing.Controls.DisplayBlebLed"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:MQTT.Sharing.Converters"
             xmlns:local="clr-namespace:MQTT.Sharing.Controls"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BatteryColorConverter x:Key="BatteryColorConverter"/>
    </UserControl.Resources>
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" 
            DataContext="{Binding BlebSensor, ElementName=myUserControl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" >
        <TextBlock FontSize="{Binding SensorIdFontSize, ElementName=myUserControl}"
            Text="{Binding Sensor_Area, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontWeight="SemiBold"
            HorizontalAlignment="Center" Margin="0 0 0 2" Foreground="{StaticResource Azure2}"/>
        <Grid Width="{Binding CircleSize, ElementName=myUserControl}" 
            Height="{Binding CircleSize, ElementName=myUserControl}">
            <Ellipse Stroke="{StaticResource Azure2}" StrokeThickness="1">
                <Ellipse.Fill>
                    <MultiBinding Converter="{StaticResource LedColorConverter}">
                        <Binding Path="Sensor_Status" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
                        <Binding Path="Presence" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
                    </MultiBinding>
                </Ellipse.Fill>
            </Ellipse>
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="LocationText" Text="{Binding Sensor_Location, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        FontSize="{Binding LocationFontSize, ElementName=myUserControl}" FontWeight="SemiBold" Foreground="{StaticResource Azure2}">
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="TextBlock.Loaded">
                            <BeginStoryboard Name="InitialLoadStoryboard">
                                <Storyboard>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
                <TextBlock x:Name="TimerText" HorizontalAlignment="Center"
                    Text="{Binding ElapsedSeconds, ElementName=myUserControl, Converter={StaticResource SecondsToMMSSConverter}}"
                    Visibility="Collapsed" 
                    FontSize="{Binding TimerFontSize, ElementName=myUserControl}" FontWeight="SemiBold" Foreground="{StaticResource Azure2}"/>
            </StackPanel>

        </Grid>
        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" VerticalAlignment="Center" 
            FontSize="{Binding SensorIdFontSize, ElementName=myUserControl}"
            Text="{Binding Battery, StringFormat='{}{0}V', Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Foreground="{Binding Battery, Converter={StaticResource BatteryColorConverter}}"/>
    </StackPanel>
</UserControl>

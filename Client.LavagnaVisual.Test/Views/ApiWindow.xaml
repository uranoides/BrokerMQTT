<Window x:Name="myWindow" x:Class="Client.LavagnaVisual.Test.Views.ApiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Client.LavagnaVisual.Test.Views"
        xmlns:cmd="clr-namespace:Client.LavagnaVisual.Test.Commands"
        mc:Ignorable="d" WindowStartupLocation="CenterScreen"
        Title="Test Api Lavagna Visual" Height="400" Width="700">
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static cmd:ApiCommands.GetRecipes}" Executed="GetRecipesExecuted"/>
    </Window.CommandBindings>
    <Border Style="{DynamicResource LinearHorizontalBorderBackground}">
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Row="0" Margin="0 0 5 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>
                <ContentControl Grid.Row="0" Content="GetRecipes" Template="{StaticResource TextBlockTemplate}" HorizontalAlignment="Center"
                    FontSize="{DynamicResource FontSize11}" Foreground="{DynamicResource Yellow3}" FontWeight="Medium" VerticalAlignment="Top" Focusable="False"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1" Width="25" Height="25" Template="{DynamicResource TimeButtonTemplate}"
                        Command="{x:Static cmd:ApiCommands.GetRecipes}" 
                        ToolTip="Read Topic">
                    </Button>
                </Grid>
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <ContentControl Grid.Row="0" Margin="0 5 0 0" Content="Response" Template="{StaticResource TextBlockTemplate}" 
                        FontSize="{DynamicResource FontSize11}" Foreground="{DynamicResource Azure3}" FontWeight="Medium" VerticalAlignment="Top" Focusable="False"/>
                    <DataGrid x:Name="dgRecipes" Background="Transparent" 
                        Foreground="{StaticResource Azure1}" HeadersVisibility="None"
                        Grid.Row="1" RowBackground="Transparent"
                        AutoGenerateColumns="True" 
                        IsReadOnly="True" />
                </Grid>
                <Grid Grid.Row="3" Margin="0 5 0 0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock VerticalAlignment="Top" Grid.Row="0" HorizontalAlignment="Left"
                        Foreground="{StaticResource Azure3}" FontWeight="SemiBold" FontSize="{StaticResource FontSize11}"
                        Text="{Binding LastStatusNotification, ElementName=myWindow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock VerticalAlignment="Top" Grid.Row="1" HorizontalAlignment="Left"
                        Foreground="{StaticResource Red6}" FontWeight="SemiBold" FontSize="{StaticResource FontSize11}"
                        Text="{Binding LastError, ElementName=myWindow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </Grid>
            
        </Grid>
    </Border>
</Window>
